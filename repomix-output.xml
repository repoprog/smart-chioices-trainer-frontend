  confirmPassword: z.string()
}).refine((data) => data.password === data.confirmPassword, {
  message: "Hasła nie pasują do siebie",
  path: ["confirmPassword"],
});

export function RegisterModal({ isOpen, onClose, onSwitchToLogin }) {
