  const {
    register,
    handleSubmit,
    formState: { errors },
    reset, // <-- DODANE
  } = useForm({
    resolver: zodResolver(registerSchema),
  });

  // DODANE: Bezpieczne zamykanie
  const handleClose = () => {
    reset();
    setGlobalError("");
    onClose();
  };

  // DODANE: Bezpieczne przełączanie
